LORE_TRANSPORT=streamable-http
LORE_DB_PATH=/var/lib/lore/lore_memory.db
LORE_AUDIT_DB_PATH=/var/lib/lore/lore_audit.db
LORE_DR_SNAPSHOT_DIR=/var/lib/lore/snapshots
LORE_OIDC_ALLOWED_ALGS=RS256
LORE_OIDC_ISSUER=https://issuer.example.com/
LORE_OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# LORE_ENCRYPTION_PASSPHRASE=replace-with-secret
# LORE_ENCRYPTION_SALT=replace-with-base64-salt