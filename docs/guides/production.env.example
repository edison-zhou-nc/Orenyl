ORENYL_TRANSPORT=streamable-http
ORENYL_DB_PATH=/var/lib/orenyl/orenyl_memory.db
ORENYL_AUDIT_DB_PATH=/var/lib/orenyl/orenyl_audit.db
ORENYL_DR_SNAPSHOT_DIR=/var/lib/orenyl/orenyl_snapshots
ORENYL_OIDC_ALLOWED_ALGS=RS256
ORENYL_OIDC_ISSUER=https://issuer.example.com/
ORENYL_OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# ORENYL_ENCRYPTION_PASSPHRASE=replace-with-secret
# ORENYL_ENCRYPTION_SALT=cGxhY2Vob2xkZXItYmFzZTY0LXNhbHQ=
